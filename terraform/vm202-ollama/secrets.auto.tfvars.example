# Copy to secrets.auto.tfvars and fill in your values.
# Terraform loads *.auto.tfvars automatically — no -var-file flag needed.
# This file is gitignored — never commit secrets.auto.tfvars.
#
# Token must belong to root@pam — other users cannot create privileged containers.
# Create with: pveum user token add root@pam terraform --privsep=0

proxmox_api_token_id     = "root@pam!terraform"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
