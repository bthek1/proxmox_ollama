# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

proxmox_node = "pve"
vm_id        = 202
vm_name      = "ollama-202"

# LXC template file ID on Proxmox storage.
# List available templates: ssh root@<proxmox> pveam list local
# Download template first: ssh root@<proxmox> pveam download local ubuntu-24.04-standard_24.04-2_amd64.tar.zst
template_file_id = "local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst"

cores     = 4
memory_mb = 4096   # 4 GB

disk_size  = 80
datastore  = "local-lvm"

ip_address  = "192.168.2.202/24"
gateway     = "192.168.2.1"
dns_servers = ["1.1.1.1", "8.8.8.8"]

# Paste your public key: cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... user@host"
